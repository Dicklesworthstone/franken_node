      "case": "missing_command_digest",
      "expected_error": "ERR_VFR_MISSING_COMMAND_DIGEST",
      "patch_attempt": {
        "remove": [
          "command.command_digest"
        ]
      }
    },
    {
      "case": "unsupported_timeout_class",
      "expected_error": "ERR_VFR_INVALID_TIMEOUT_CLASS",
      "patch_attempt": {
        "set": {
          "adapter_outcome.timeout_class": "not_a_timeout"
        }
      }
    },
    {
      "case": "unbounded_output_snippet",
      "expected_error": "ERR_VFR_UNBOUNDED_SNIPPET",
      "patch_attempt": {
        "set": {
          "artifacts.stdout_snippet": {
            "repeat": "x",
            "count": 4097
          }
        }
      }
    },
    {
      "case": "absolute_artifact_path",
      "expected_error": "ERR_VFR_INVALID_ARTIFACT_PATH",
      "patch_attempt": {
        "set": {
          "artifacts.stdout_path": "/tmp/stdout.txt"
        }
      }
    },
    {
      "case": "missing_next_action",
      "expected_error": "ERR_VFR_INVALID_RECOVERY_DECISION",
      "patch_recovery": {
        "remove": [
          "required_action"
        ]
      }
    },
    {
      "case": "mismatched_bead_thread",
      "expected_error": "ERR_VFR_BEAD_MISMATCH",
      "patch_recovery": {
        "set": {
          "thread_id": "bd-other"
        }
      }
    },
    {
      "case": "unredacted_environment",
      "expected_error": "ERR_VFR_UNREDACTED_ENVIRONMENT",
      "patch_attempt": {
        "set": {
          "environment.captured_env.SECRET_TOKEN": "raw-secret"
        }
      }
    },
    {
      "case": "unsorted_observations",
      "expected_error": "ERR_VFR_INVALID_OBSERVATION_ORDER",
      "patch_attempt": {
        "set": {
          "observations": [
            {
              "schema_version": "franken-node/validation-flight-recorder/observation/v1",
              "observation_id": "vfr-obs-0002",
              "observed_at": "2026-05-06T08:00:03Z",
              "phase": "progress_observed",
              "event_code": "VFR-001",
              "worker_id": "ts2",
              "rch_mode": "remote",
              "queue_state": "running",
              "message": "later observation",
              "details": {}
            },
            {
              "schema_version": "franken-node/validation-flight-recorder/observation/v1",
              "observation_id": "vfr-obs-0001",
              "observed_at": "2026-05-06T08:00:02Z",
              "phase": "adapter_classified",
              "event_code": "VFR-001",
              "worker_id": "ts2",
              "rch_mode": "remote",
              "queue_state": "completed",
              "message": "earlier observation",
              "details": {}
            }
          ]
        }
      }
    }
  ]
