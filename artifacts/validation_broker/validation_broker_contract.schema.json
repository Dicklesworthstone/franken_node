{
  "schema_version": "franken-node/validation-broker/schema-catalog/v1",
  "json_schema_draft": "https://json-schema.org/draft/2020-12/schema",
  "receipt_schema_uri": "https://franken-node.local/schemas/validation-broker/receipt/v1",
  "timeout_classes": [
    "none",
    "queue_wait",
    "rch_dispatch",
    "ssh_command",
    "cargo_test_timeout",
    "process_idle",
    "process_wall",
    "worker_unreachable",
    "unknown"
  ],
  "error_classes": [
    "none",
    "compile_error",
    "test_failure",
    "clippy_warning",
    "format_failure",
    "transport_timeout",
    "worker_infra",
    "environment_contention",
    "disk_pressure",
    "source_only",
    "unknown"
  ],
  "source_only_reasons": [
    "cargo_contention",
    "rch_unavailable",
    "sibling_dependency_blocker",
    "disk_pressure",
    "reserved_surface",
    "no_cargo_requested",
    "docs_only"
  ],
  "closeout_required_fields": [
    "receipt_id",
    "bead_id",
    "thread_id",
    "command_digest.hex",
    "timing.started_at",
    "timing.finished_at",
    "exit.kind",
    "artifacts.receipt_path",
    "trust.git_commit",
    "trust.freshness"
  ],
  "doctor_readiness_fields": [
    "queue_depth",
    "oldest_queued_age_ms",
    "active_leases",
    "expired_leases",
    "worker_reachability",
    "rch_mode_counts",
    "timeout_class_counts",
    "error_class_counts",
    "fresh_source_only_fallbacks"
  ],
  "ci_required_fields": [
    "schema_version",
    "bead_id",
    "request_ref.bead_id",
    "command_digest.hex",
    "timing.freshness_expires_at",
    "exit.kind",
    "artifacts.stdout_path",
    "artifacts.stderr_path",
    "artifacts.summary_path",
    "artifacts.receipt_path",
    "trust.git_commit",
    "trust.freshness"
  ],
  "schemas": {
    "ValidationBrokerRequest": {
      "type": "object",
      "required": [
        "schema_version",
        "request_id",
        "bead_id",
        "thread_id",
        "requester_agent",
        "created_at",
        "priority",
        "command",
        "inputs",
        "dedupe_key",
        "output_policy",
        "fallback_policy"
      ]
    },
    "BrokerQueueEntry": {
      "type": "object",
      "required": [
        "queue_id",
        "request",
        "queue_state",
        "dedupe_key",
        "lease",
        "worker_requirements",
        "observations"
      ]
    },
    "WorkerCapabilityObservation": {
      "type": "object",
      "required": [
        "observation_id",
        "worker_id",
        "observed_at",
        "rch_mode",
        "reachable",
        "capabilities",
        "failure"
      ]
    },
    "ValidationReceipt": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "https://franken-node.local/schemas/validation-broker/receipt/v1",
      "type": "object",
      "required": [
        "schema_version",
        "receipt_id",
        "request_id",
        "bead_id",
        "thread_id",
        "request_ref",
        "command",
        "command_digest",
        "environment_policy",
        "target_dir_policy",
        "input_digests",
        "rch",
        "timing",
        "exit",
        "artifacts",
        "trust",
        "classifications"
      ],
      "properties": {
        "schema_version": {
          "const": "franken-node/validation-broker/receipt/v1"
        },
        "receipt_id": {
          "type": "string",
          "minLength": 1
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "bead_id": {
          "type": "string",
          "pattern": "^bd-[A-Za-z0-9]+$"
        },
        "thread_id": {
          "type": "string",
          "pattern": "^bd-[A-Za-z0-9]+$"
        },
        "command_digest": {
          "type": "object",
          "required": [
            "algorithm",
            "hex",
            "canonical_material"
          ]
        },
        "input_digests": {
          "type": "array",
          "minItems": 1
        }
      }
    }
  }
}
